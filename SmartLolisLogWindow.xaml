<Window x:Class="VPet.Plugin.SmartLolis.SmartLolisLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Lolis Console"
        Width="900"
        Height="560"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="#0B0E12">
    <Window.Resources>
        <SolidColorBrush x:Key="BorderBrush" Color="#2BFFFFFF"/>
        <SolidColorBrush x:Key="HeadBrush" Color="#E8DFC8"/>
        <SolidColorBrush x:Key="TextBrush" Color="#D8E8F0"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#98A8B8"/>
        <SolidColorBrush x:Key="InputBrush" Color="#11161D"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="#38B966"/>
        <SolidColorBrush x:Key="AccentAzureBrush" Color="#40B0E0"/>
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#9060D0"/>

        <Style x:Key="CalendarButtonBaseStyle" TargetType="Button">
            <Setter Property="Width" Value="136" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border Height="2"
                                        VerticalAlignment="Top"
                                        Background="{TemplateBinding BorderBrush}"
                                        Opacity="0.9" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="10,0"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CopyButtonStyle" TargetType="Button" BasedOn="{StaticResource CalendarButtonBaseStyle}">
            <Setter Property="Background" Value="#1638B966" />
            <Setter Property="BorderBrush" Value="#6038B966" />
        </Style>

        <Style x:Key="RefreshButtonStyle" TargetType="Button" BasedOn="{StaticResource CalendarButtonBaseStyle}">
            <Setter Property="Background" Value="#1640B0E0" />
            <Setter Property="BorderBrush" Value="#6040B0E0" />
        </Style>

        <Style x:Key="ClearButtonStyle" TargetType="Button" BasedOn="{StaticResource CalendarButtonBaseStyle}">
            <Setter Property="Background" Value="#169060D0" />
            <Setter Property="BorderBrush" Value="#609060D0" />
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CalendarButtonBaseStyle}">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="SMART LOLIS LOG" FontFamily="Impact" FontSize="28" Foreground="{StaticResource HeadBrush}" />
            <TextBlock Margin="0,6,0,0" Text="Here you can see ElevenLabs, Groq, save/load, and playback errors." Foreground="{StaticResource MutedBrush}" FontFamily="Bahnschrift" />
        </StackPanel>

        <TextBox Grid.Row="1"
                 x:Name="txtLog"
                 Margin="0,14,0,14"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"
                 Background="{StaticResource InputBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 BorderThickness="1"
                 Padding="12" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Copy Log" Style="{StaticResource CopyButtonStyle}" Click="BtnCopy_Click" />
            <Button Content="Refresh" Style="{StaticResource RefreshButtonStyle}" Click="BtnRefresh_Click" />
            <Button Content="Clear" Style="{StaticResource ClearButtonStyle}" Click="BtnClear_Click" />
            <Button Content="Close" Style="{StaticResource CloseButtonStyle}" Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
